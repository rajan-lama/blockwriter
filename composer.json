{
	"name": "administrator/gutnestar",
	"description": "Gutenstar is a WordPress Plugins for ultimate gutenberg blocks and patterns.",
	"License": "GPL-3-0",
	"version": "1.0.0",
	"keywords": [
		"wordpress",
		"plugin"
	],
	"requires": {
		"php": ">=5.6.0"
	},
	"homepage": "https://demo.prosysthemes.com/gutenstar",
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/php-compatibility": "*"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"autoload": {
		"psr-4": {
			"Administrator\\Gutenstar\\": "includes/"
		}
	},
	"authors": [
		{
			"name": "prosysthemes",
			"email": "prosysthemes@gmail.com"
		}
	]
}
