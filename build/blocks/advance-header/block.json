{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockwriter/advance-header",
  "version": "0.1.0",
  "title": "⭐️ Advance Header",
  "category": "blockwriter",
  "icon": "heading",
  "description": "Stylish header with advaance options.",
  "example": {},
  "keywords": [
    "header"
  ],
  "supports": {
    "html": true
  },
  "attributes": {
    "header": {
      "type": "string",
      "default": "h1"
    },
    "content": {
      "type": "string",
      "default": "Heading"
    },
    "headerBgColor": {
      "type": "string",
      "default": "#000"
    },
    "headerTextColor": {
      "type": "string",
      "default": "#eee"
    },
    "headerIcon": {
      "type": "string",
      "default": "unfold"
    },
    "headerIconColor": {
      "type": "string",
      "default": "#fff"
    },
    "bodyBgColor": {
      "type": "string"
    },
    "bodyTextColor": {
      "type": "string"
    },
    "borderStyle": {
      "type": "string",
      "default": "solid"
    },
    "borderWidth": {
      "type": "number",
      "default": 0
    },
    "borderColor": {
      "type": "string"
    },
    "borderRadius": {
      "type": "number",
      "default": 2
    },
    "marginBottom": {
      "type": "number",
      "default": 15
    },
    "changed": {
      "type": "boolean",
      "default": false
    },
    "blockAlignment": {
      "type": "string",
      "default": false
    },
    "highContrast": {
      "type": "boolean",
      "default": "false"
    }
  },
  "textdomain": "blockwriter",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}