{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockwriter/carousel",
  "version": "0.1.0",
  "title": "BW Carousel",
  "category": "blockwriter",
  "icon": "smiley",
  "description": "Carousel block for blockwriter.",
  "example": {},
  "keywords": [
    "carousel",
    "slider",
    "gallery"
  ],
  "supports": {
    "color": {
      "background": false,
      "text": true
    },
    "html": false,
    "typography": {
      "fontSize": true
    }
  },
  "attributes": {
    "slides": {
      "type": "array",
      "default": [
        {
          "id": 1,
          "title": "Slide 1",
          "subtitle": "Subtitle 1",
          "description": "Description for slide 1",
          "image": "https://via.placeholder.com/800x400?text=Slide+1",
          "btn1Text": "Learn More",
          "btn1Url": "#",
          "btn2Text": "Buy Now",
          "btn2Url": "#"
        },
        {
          "id": 2,
          "title": "Slide 2",
          "subtitle": "Subtitle 2",
          "description": "Description for slide 2",
          "image": "https://via.placeholder.com/800x400?text=Slide+2",
          "btn1Text": "Learn More",
          "btn1Url": "#",
          "btn2Text": "Buy Now",
          "btn2Url": "#"
        }
      ]
    },
    "activeIndex": {
      "type": "number",
      "default": 0
    },
    "styles": {
      "type": "object",
      "default": {
        "textColor": "#000000",
        "bgColor": "#ffffff",
        "padding": 20
      }
    },
    "preview": {
      "type": "boolean",
      "default": false
    },
    "showTitle": {
      "type": "boolean",
      "default": true
    },
    "showSubtitle": {
      "type": "boolean",
      "default": true
    },
    "showDescription": {
      "type": "boolean",
      "default": true
    },
    "showPrimaryButtons": {
      "type": "boolean",
      "default": true
    },
    "showSecondaryButtons": {
      "type": "boolean",
      "default": true
    },
    "interval": {
      "type": "number",
      "default": 3000
    },
    "showIndicators": {
      "type": "boolean",
      "default": true
    },
    "showControls": {
      "type": "boolean",
      "default": true
    },
    "slideEffect": {
      "type": "string",
      "default": "slide"
    }
  },
  "textdomain": "blockwriter",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}