		"@wordpress/date": "^5.42.0",
		"@wordpress/deprecated": "^4.42.0",
		"@wordpress/dom": "^4.42.0",
		"@wordpress/element": "^6.42.0",
		"@wordpress/fields": "^0.34.0",
