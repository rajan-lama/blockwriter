{
	"name": "@wordpress/widgets",
	"version": "4.42.0",
	"description": "Functionality used by the widgets block editor in the Widgets screen and the Customizer.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/packages/widgets/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/WordPress/gutenberg.git",
		"directory": "packages/widgets"
	},
	"bugs": {
		"url": "https://github.com/WordPress/gutenberg/issues"
	},
	"engines": {
		"node": ">=18.12.0",
		"npm": ">=8.19.2"
	},
	"files": [
		"src",
		"build",
		"build-module",
		"build-style",
		"build-types",
		"*.md"
	],
	"main": "build/index.cjs",
	"module": "build-module/index.mjs",
	"exports": {
		".": {
			"import": "./build-module/index.mjs",
			"require": "./build/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"react-native": "src/index",
	"wpScript": true,
	"wpCopyFiles": {
		"files": [
			"src/blocks/**/*.php",
			"src/blocks/*/block.json"
		],
		"transforms": {
			"php": {
				"functionPrefix": "gutenberg_",
				"classSuffix": "_Gutenberg",
				"prefixFunctions": [
					"wp_apply_colors_support",
					"wp_enqueue_block_support_styles",
					"wp_get_typography_font_size_value",
					"wp_style_engine_get_styles",
					"wp_get_global_settings"
				],
				"suffixClasses": [
					"WP_Navigation_Block_Renderer"
				],
				"addActionPriority": 20,
				"flattenIndexFiles": true
			}
		}
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.42.0",
		"@wordpress/base-styles": "^6.18.0",
		"@wordpress/block-editor": "^15.15.0",
		"@wordpress/blocks": "^15.15.0",
		"@wordpress/components": "^32.4.0",
		"@wordpress/compose": "^7.42.0",
		"@wordpress/core-data": "^7.42.0",
		"@wordpress/data": "^10.42.0",
		"@wordpress/element": "^6.42.0",
		"@wordpress/i18n": "^6.15.0",
		"@wordpress/icons": "^12.0.0",
		"@wordpress/notices": "^5.42.0",
		"clsx": "^2.1.1"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"gitHead": "c20787b1778ae64c2db65643b1c236309d68e6ba"
}
