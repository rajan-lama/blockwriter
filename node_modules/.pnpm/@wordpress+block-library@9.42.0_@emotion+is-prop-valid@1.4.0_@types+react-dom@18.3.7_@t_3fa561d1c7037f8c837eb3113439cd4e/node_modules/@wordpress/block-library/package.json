{
	"name": "@wordpress/block-library",
	"version": "9.42.0",
	"description": "Block library for the WordPress editor.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"blocks"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/packages/block-library/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/WordPress/gutenberg.git",
		"directory": "packages/block-library"
	},
	"bugs": {
		"url": "https://github.com/WordPress/gutenberg/issues"
	},
	"engines": {
		"node": ">=18.12.0",
		"npm": ">=8.19.2"
	},
	"files": [
		"src",
		"build",
		"build-module",
		"build-style",
		"build-types",
		"*.md",
		"babel-plugin.cjs"
	],
	"main": "build/index.cjs",
	"module": "build-module/index.mjs",
	"exports": {
		".": {
			"import": "./build-module/index.mjs",
			"require": "./build/index.cjs"
		},
		"./babel-plugin": "./babel-plugin.cjs",
		"./build-module/*": "./build-module/*",
		"./build-style/*": "./build-style/*",
		"./package.json": "./package.json"
	},
	"react-native": "src/index",
	"wpScript": true,
	"wpScriptModuleExports": {
		"./accordion/view": "./build-module/accordion/view.mjs",
		"./file/view": "./build-module/file/view.mjs",
		"./form/view": "./build-module/form/view.mjs",
		"./image/view": "./build-module/image/view.mjs",
		"./navigation/view": "./build-module/navigation/view.mjs",
		"./playlist/view": "./build-module/playlist/view.mjs",
		"./query/view": "./build-module/query/view.mjs",
		"./search/view": "./build-module/search/view.mjs",
		"./tabs/view": "./build-module/tabs/view.mjs"
	},
	"wpStyleEntryPoints": [
		"src/*.scss",
		"src/*/style.scss",
		"src/*/editor.scss",
		"src/*/theme.scss"
	],
	"wpCopyFiles": {
		"files": [
			"src/**/*.php",
			"src/*/block.json"
		],
		"transforms": {
			"php": {
				"functionPrefix": "gutenberg_",
				"classSuffix": "_Gutenberg",
				"prefixFunctions": [
					"wp_apply_colors_support",
					"wp_enqueue_block_support_styles",
					"wp_get_typography_font_size_value",
					"wp_style_engine_get_styles",
					"wp_get_global_settings"
				],
				"suffixClasses": [
					"WP_Navigation_Block_Renderer"
				],
				"addActionPriority": 20,
				"flattenIndexFiles": true
			}
		}
	},
	"sideEffects": [
		"build-style/**",
		"src/**/*.scss",
		"src/*/init.js",
		"build/*/init.js",
		"build-module/*/init.mjs"
	],
	"dependencies": {
		"@arraypress/waveform-player": "1.2.1",
		"@wordpress/a11y": "^4.42.0",
		"@wordpress/api-fetch": "^7.42.0",
		"@wordpress/autop": "^4.42.0",
		"@wordpress/base-styles": "^6.18.0",
		"@wordpress/blob": "^4.42.0",
		"@wordpress/block-editor": "^15.15.0",
		"@wordpress/blocks": "^15.15.0",
		"@wordpress/components": "^32.4.0",
		"@wordpress/compose": "^7.42.0",
		"@wordpress/core-data": "^7.42.0",
		"@wordpress/data": "^10.42.0",
		"@wordpress/date": "^5.42.0",
		"@wordpress/deprecated": "^4.42.0",
		"@wordpress/dom": "^4.42.0",
		"@wordpress/element": "^6.42.0",
		"@wordpress/escape-html": "^3.42.0",
		"@wordpress/hooks": "^4.42.0",
		"@wordpress/html-entities": "^4.42.0",
		"@wordpress/i18n": "^6.15.0",
		"@wordpress/icons": "^12.0.0",
		"@wordpress/interactivity": "^6.42.0",
		"@wordpress/interactivity-router": "^2.42.0",
		"@wordpress/keyboard-shortcuts": "^5.42.0",
		"@wordpress/keycodes": "^4.42.0",
		"@wordpress/latex-to-mathml": "^1.10.0",
		"@wordpress/notices": "^5.42.0",
		"@wordpress/patterns": "^2.42.0",
		"@wordpress/primitives": "^4.42.0",
		"@wordpress/private-apis": "^1.42.0",
		"@wordpress/reusable-blocks": "^5.42.0",
		"@wordpress/rich-text": "^7.42.0",
		"@wordpress/server-side-render": "^6.18.0",
		"@wordpress/upload-media": "^0.27.0",
		"@wordpress/url": "^4.42.0",
		"@wordpress/viewport": "^6.42.0",
		"@wordpress/wordcount": "^4.42.0",
		"change-case": "^4.1.2",
		"clsx": "^2.1.1",
		"colord": "^2.7.0",
		"fast-average-color": "^9.1.1",
		"fast-deep-equal": "^3.1.3",
		"html-react-parser": "5.2.11",
		"memize": "^2.1.0",
		"remove-accents": "^0.5.0",
		"uuid": "^9.0.1"
	},
	"devDependencies": {
		"deep-freeze": "0.0.1"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"gitHead": "c20787b1778ae64c2db65643b1c236309d68e6ba"
}
