{
	"name": "@wordpress/plugins",
	"version": "7.42.0",
	"description": "Plugins module for WordPress.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"plugins"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/packages/plugins/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/WordPress/gutenberg.git",
		"directory": "packages/plugins"
	},
	"bugs": {
		"url": "https://github.com/WordPress/gutenberg/issues"
	},
	"engines": {
		"node": ">=18.12.0",
		"npm": ">=8.19.2"
	},
	"files": [
		"src",
		"build",
		"build-module",
		"build-types",
		"*.md"
	],
	"main": "build/index.cjs",
	"module": "build-module/index.mjs",
	"exports": {
		".": {
			"types": "./build-types/index.d.ts",
			"import": "./build-module/index.mjs",
			"require": "./build/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"react-native": "src/index",
	"wpScript": true,
	"types": "build-types",
	"dependencies": {
		"@wordpress/components": "^32.4.0",
		"@wordpress/compose": "^7.42.0",
		"@wordpress/deprecated": "^4.42.0",
		"@wordpress/element": "^6.42.0",
		"@wordpress/hooks": "^4.42.0",
		"@wordpress/icons": "^12.0.0",
		"@wordpress/is-shallow-equal": "^5.42.0",
		"memize": "^2.0.1"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"gitHead": "c20787b1778ae64c2db65643b1c236309d68e6ba"
}
