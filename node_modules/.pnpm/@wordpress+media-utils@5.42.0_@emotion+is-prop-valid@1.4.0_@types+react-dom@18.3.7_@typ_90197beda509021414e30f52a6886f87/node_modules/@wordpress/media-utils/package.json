{
	"name": "@wordpress/media-utils",
	"version": "5.42.0",
	"description": "WordPress Media Upload Utils.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"media",
		"upload"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/packages/media-utils/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/WordPress/gutenberg.git",
		"directory": "packages/media-utils"
	},
	"bugs": {
		"url": "https://github.com/WordPress/gutenberg/issues"
	},
	"engines": {
		"node": ">=18.12.0",
		"npm": ">=8.19.2"
	},
	"files": [
		"src",
		"build",
		"build-module",
		"build-style",
		"build-types",
		"*.md"
	],
	"main": "build/index.cjs",
	"module": "build-module/index.mjs",
	"exports": {
		".": {
			"types": "./build-types/index.d.ts",
			"import": "./build-module/index.mjs",
			"require": "./build/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"wpScript": true,
	"types": "build-types",
	"sideEffects": [
		"build-style/**"
	],
	"dependencies": {
		"@wordpress/api-fetch": "^7.42.0",
		"@wordpress/base-styles": "^6.18.0",
		"@wordpress/blob": "^4.42.0",
		"@wordpress/components": "^32.4.0",
		"@wordpress/core-data": "^7.42.0",
		"@wordpress/data": "^10.42.0",
		"@wordpress/dataviews": "^13.1.0",
		"@wordpress/element": "^6.42.0",
		"@wordpress/i18n": "^6.15.0",
		"@wordpress/icons": "^12.0.0",
		"@wordpress/media-fields": "^0.7.0",
		"@wordpress/notices": "^5.42.0",
		"@wordpress/private-apis": "^1.42.0",
		"@wordpress/ui": "^0.9.0",
		"clsx": "^2.1.1"
	},
	"peerDependencies": {
		"react": "^18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"gitHead": "c20787b1778ae64c2db65643b1c236309d68e6ba"
}
