#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules/create-jest/bin/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules/create-jest/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/node_modules:/opt/homebrew/var/www/testwp/wp-content/node_modules:/opt/homebrew/var/www/testwp/node_modules:/opt/homebrew/var/www/node_modules:/opt/homebrew/var/node_modules:/opt/homebrew/node_modules:/opt/node_modules:/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules/create-jest/bin/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules/create-jest/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/node_modules:/opt/homebrew/var/www/testwp/wp-content/node_modules:/opt/homebrew/var/www/testwp/node_modules:/opt/homebrew/var/www/node_modules:/opt/homebrew/var/node_modules:/opt/homebrew/node_modules:/opt/node_modules:/node_modules:/opt/homebrew/var/www/testwp/wp-content/plugins/blockwriter/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../create-jest/bin/create-jest.js" "$@"
else
  exec node  "$basedir/../create-jest/bin/create-jest.js" "$@"
fi
