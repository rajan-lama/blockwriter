{
  "name": "blockwriter",
  "version": "0.1.0",
  "description": "Blockwriter is Advanced gutenberg block.",
  "author": "rithemesofficial",
  "license": "GPL-2.0-or-later",
  "main": "dist/index.js",
  "scripts": {
    "format": "wp-scripts format",
    "build:admin": "wp-scripts build admin.js --webpack-src-dir=src/admin --webpack-copy-php --output-path=admin/js/dist",
    "build:public": "wp-scripts build public.js --webpack-src-dir=src/public --webpack-copy-php --output-path=public/js/dist",
    "build:blocks": "wp-scripts build --webpack-src-dir=src/blocks --webpack-copy-php --output-path=blocks",
    "start:admin": "wp-scripts start admin.js --webpack-src-dir=src/admin --webpack-copy-php --output-path=admin/js/dist",
    "start:public": "wp-scripts start public.js --webpack-src-dir=src/public --webpack-copy-php --output-path=public/js/dist",
    "start:blocks": "wp-scripts start --webpack-src-dir=src/blocks --webpack-copy-php --output-path=blocks",
    "start": "npm-run-all --parallel format start:admin start:public start:blocks ",
    "packages-update": "wp-scripts packages-update",
    "build": "npm-run-all --parallel format build:admin build:public build:blocks",
    "lint:php": "vendor\\bin\\phpcs",
    "lint:php:fix": "vendor\\bin\\phpcbf",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "plugin-zip": "wp-scripts plugin-zip",
    "test:unit": "wp-scripts test-unit-js",
    "test": "npm run lint:js && npm run link.css && npm run test-unit-js"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@wordpress/api-fetch": "^7.43.0",
    "@wordpress/block-editor": "^14.21.0",
    "@wordpress/blocks": "^13.10.0",
    "@wordpress/components": "^28.13.0",
    "@wordpress/core-data": "^7.43.0",
    "@wordpress/data": "^10.43.0",
    "@wordpress/data-controls": "^4.43.0",
    "@wordpress/edit-post": "^8.43.0",
    "@wordpress/element": "^6.43.0",
    "@wordpress/icons": "^10.32.0",
    "@wordpress/plugins": "^7.43.0",
    "@wordpress/scripts": "^30.27.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "animate": "^1.0.0",
    "animate.css": "^4.1.1",
    "autoprefixer": "^10.4.27",
    "lodash": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "react-bootstrap": "^2.10.10",
    "react-dnd": "^16.0.1",
    "react-router-dom": "^6.30.3",
    "react-slick": "^0.30.3",
    "slick-carousel": "^1.8.1",
    "swiper": "^12.1.3"
  },
  "imports": {
    "@blocks/*": "./src/blocks/*",
    "@components/*": "./src/components/*",
    "@hooks/*": "./src/hooks/*",
    "@constants/*": "./src/constants/*"
  }
}
