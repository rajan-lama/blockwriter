{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockwriter/slider-child",
  "version": "0.1.0",
  "title": "⭐️ Single Slide",
  "category": "blockwriter",
  "icon": "smiley",
  "example": {},
  "description": "Slider block for blockwriter.",
  "keywords": ["slider"],
  "supports": {
    "html": true,
    "inserter": false
  },
  "attributes": {
    "generatedCss": {
      "type": "array"
    },
    "hasparent": {
      "type": "boolean",
      "default": false
    },
    "containerType": {
      "type": "string",
      "default": "default"
    },
    "contentType": {
      "type": "string",
      "default": "full-width"
    },
    "width": {
      "type": "string",
      "default": ""
    },
    "widthUnit": {
      "type": "string",
      "default": ""
    },
    "contentBoxWidthDesktop": {
      "type": "string",
      "default": "1200px"
    },
    "contentBoxWidthTablet": {
      "type": "string",
      "default": "1024px"
    },
    "contentBoxWidthMobile": {
      "type": "string",
      "default": "767px"
    },
    "contentBoxHeightDesktop": {
      "type": "string",
      "default": "1000px"
    },
    "contentBoxHeightTablet": {
      "type": "string",
      "default": "1200px"
    },
    "contentBoxHeightMobile": {
      "type": "string",
      "default": "1000px"
    },
    "autoHeight": {
      "type": "boolean",
      "default": false
    },
    "htmlTag": {
      "type": "string",
      "default": "div"
    },
    "overflow": {
      "type": "string",
      "default": "hidden"
    },
    "sticky": {
      "type": "boolean",
      "default": false
    },
    "stickyPosition": {
      "type": "string",
      "default": "top"
    },
    "stickyOffsetValue": {
      "type": "number",
      "default": 0
    },
    "animation": {
      "type": "string",
      "default": "none"
    },
    "animationDuration": {
      "type": "string",
      "default": "slow"
    },
    "hideOnDesktop": {
      "type": "boolean",
      "default": false
    },
    "hideOnTablet": {
      "type": "boolean",
      "default": false
    },
    "hideOnMobile": {
      "type": "boolean",
      "default": false
    },
    "zindex": {
      "type": "number",
      "default": 0
    },
    "bodyBgColor": {
      "type": "string"
    },
    "bodyTextColor": {
      "type": "string"
    },
    "borderStyle": {
      "type": "string",
      "default": "solid"
    },
    "borderWidth": {
      "type": "number",
      "default": 0
    },
    "borderColor": {
      "type": "string"
    },
    "borderRadius": {
      "type": "number",
      "default": 2
    },
    "marginBottom": {
      "type": "number",
      "default": 15
    },
    "changed": {
      "type": "boolean",
      "default": false
    },
    "margin": {
      "type": "object",
      "default": {
        "top": "90px",
        "right": "0px",
        "left": "0px",
        "bottom": "90px",
        "locked": true
      }
    },
    "padding": {
      "type": "object",
      "default": {
        "top": "auto",
        "right": "auto",
        "left": "auto",
        "bottom": "auto",
        "locked": true
      }
    }
  },
  "textdomain": "blockwriter",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}
